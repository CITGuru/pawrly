{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config",
  "description": "Top-level workspace config.",
  "type": "object",
  "required": [
    "version"
  ],
  "properties": {
    "defaults": {
      "description": "Workspace defaults.",
      "default": {
        "cache": {
          "mode": {
            "mode": "none"
          },
          "storage": "~/.pawrly/cache"
        },
        "engine": {
          "duckdb_pool_size": 8,
          "max_concurrent_queries": 16,
          "memory_limit_bytes": null,
          "query_timeout": "5m"
        },
        "http": {
          "timeout": "30s",
          "user_agent": "pawrly/0.0.1"
        },
        "optimizer": {
          "coalesce_batches": true,
          "dynamic_filter_pushdown": false,
          "join_reorder": true
        },
        "safety": {
          "max_unfiltered_rows": 1000000
        }
      },
      "allOf": [
        {
          "$ref": "#/definitions/Defaults"
        }
      ]
    },
    "include": {
      "description": "Files (or glob patterns) whose `sources:` and optional `secrets:` are merged into this config before validation. Resolved relative to the declaring file.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "name": {
      "description": "Workspace name. Defaults to `\"default\"`.",
      "default": "default",
      "type": "string"
    },
    "secrets": {
      "description": "Configured secret backends. Empty = use the built-in default chain (`env`, then OS keyring under `service=pawrly`).",
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/SecretsBackendDef"
      }
    },
    "semantic": {
      "description": "Optional semantic layer. Absent = the layer is off and behavior is unchanged.",
      "anyOf": [
        {
          "$ref": "#/definitions/SemanticConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "sources": {
      "description": "Declared sources.",
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/SourceDef"
      }
    },
    "version": {
      "description": "Schema version. Only `1` is accepted in v1.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "additionalProperties": false,
  "definitions": {
    "CacheDefaults": {
      "description": "Cache section under `defaults:`.",
      "type": "object",
      "properties": {
        "mode": {
          "description": "Default cache mode applied to tables that don't declare their own.",
          "default": {
            "mode": "none"
          },
          "allOf": [
            {
              "$ref": "#/definitions/CachePolicy"
            }
          ]
        },
        "namespace": {
          "description": "Sub-directory of `storage` that isolates this workspace's cached data. When unset, a stable id is derived from the workspace path so different workspaces sharing the same `storage` root never collide on identical `schema.table` names. Set it explicitly to pin a stable namespace (e.g. across a moved directory) or to deliberately share a cache between workspaces.",
          "type": [
            "string",
            "null"
          ]
        },
        "storage": {
          "description": "Filesystem path used as the cache root. `~/.pawrly/cache` by default.",
          "default": "~/.pawrly/cache",
          "type": "string"
        }
      }
    },
    "CachePolicy": {
      "description": "Per-table cache mode declared in YAML.",
      "oneOf": [
        {
          "description": "Default. No caching; every query hits the live source.",
          "type": "object",
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "none"
              ]
            }
          }
        },
        {
          "description": "Read from the cache if fresher than `ttl`; else fetch live and write through.",
          "type": "object",
          "required": [
            "mode",
            "ttl"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "ttl"
              ]
            },
            "ttl": {
              "type": "string"
            }
          }
        },
        {
          "description": "Always read from the cache; a background task re-fetches every `every`.",
          "type": "object",
          "required": [
            "every",
            "mode"
          ],
          "properties": {
            "every": {
              "type": "string"
            },
            "mode": {
              "type": "string",
              "enum": [
                "refresh"
              ]
            }
          }
        },
        {
          "description": "Same as `refresh`, scheduled by cron expression.",
          "type": "object",
          "required": [
            "cron",
            "mode"
          ],
          "properties": {
            "cron": {
              "type": "string"
            },
            "mode": {
              "type": "string",
              "enum": [
                "cron"
              ]
            }
          }
        },
        {
          "description": "Incremental: a `cursor_column` is used to fetch only newer rows on each refresh.",
          "type": "object",
          "required": [
            "cursor_column",
            "mode"
          ],
          "properties": {
            "cursor_column": {
              "type": "string"
            },
            "mode": {
              "type": "string",
              "enum": [
                "append"
              ]
            }
          }
        }
      ]
    },
    "Defaults": {
      "description": "Workspace-level defaults that apply unless overridden per source / table.",
      "type": "object",
      "properties": {
        "cache": {
          "default": {
            "mode": {
              "mode": "none"
            },
            "storage": "~/.pawrly/cache"
          },
          "allOf": [
            {
              "$ref": "#/definitions/CacheDefaults"
            }
          ]
        },
        "engine": {
          "default": {
            "duckdb_pool_size": 8,
            "max_concurrent_queries": 16,
            "memory_limit_bytes": null,
            "query_timeout": "5m"
          },
          "allOf": [
            {
              "$ref": "#/definitions/EngineDefaults"
            }
          ]
        },
        "http": {
          "default": {
            "timeout": "30s",
            "user_agent": "pawrly/0.0.1"
          },
          "allOf": [
            {
              "$ref": "#/definitions/HttpDefaults"
            }
          ]
        },
        "optimizer": {
          "default": {
            "coalesce_batches": true,
            "dynamic_filter_pushdown": false,
            "join_reorder": true
          },
          "allOf": [
            {
              "$ref": "#/definitions/OptimizerDefaults"
            }
          ]
        },
        "safety": {
          "default": {
            "max_unfiltered_rows": 1000000
          },
          "allOf": [
            {
              "$ref": "#/definitions/SafetyDefaults"
            }
          ]
        }
      }
    },
    "Dimension": {
      "description": "A groupable attribute. `expr` is a raw SQL fragment over the base table.",
      "type": "object",
      "required": [
        "expr",
        "name",
        "type"
      ],
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "expr": {
          "type": "string"
        },
        "grains": {
          "description": "Valid time grains; meaningful only when `data_type == Time`.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/TimeGrain"
          }
        },
        "name": {
          "type": "string"
        },
        "type": {
          "$ref": "#/definitions/DimensionType"
        }
      }
    },
    "DimensionType": {
      "description": "The kind of a dimension.",
      "type": "string",
      "enum": [
        "string",
        "number",
        "time",
        "bool"
      ]
    },
    "EngineDefaults": {
      "description": "Engine section under `defaults:`.",
      "type": "object",
      "properties": {
        "duckdb_pool_size": {
          "description": "Size of the DuckDB connection pool (in-memory).",
          "default": 8,
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "max_concurrent_queries": {
          "description": "Maximum concurrent queries served from a single engine instance.",
          "default": 16,
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "memory_limit_bytes": {
          "description": "Memory limit passed to DataFusion's memory pool. `None` = unlimited.",
          "default": null,
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "query_timeout": {
          "description": "Per-query timeout.",
          "default": "5m",
          "type": "string"
        }
      }
    },
    "FilterOp": {
      "description": "Comparison operators usable in a [`SemanticFilter`].",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "equals",
            "not_equals",
            "in",
            "not_in",
            "gt",
            "gte",
            "lt",
            "lte",
            "contains",
            "starts_with",
            "ends_with",
            "is_null",
            "is_not_null"
          ]
        },
        {
          "description": "`values: [start, end]` → `BETWEEN start AND end`.",
          "type": "string",
          "enum": [
            "in_range"
          ]
        }
      ]
    },
    "HttpDefaults": {
      "description": "HTTP section under `defaults:`.",
      "type": "object",
      "properties": {
        "timeout": {
          "default": "30s",
          "type": "string"
        },
        "user_agent": {
          "default": "pawrly/0.0.1",
          "type": "string"
        }
      }
    },
    "Measure": {
      "description": "An aggregation formula.",
      "type": "object",
      "required": [
        "agg",
        "expr",
        "name"
      ],
      "properties": {
        "agg": {
          "$ref": "#/definitions/MeasureAgg"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "expr": {
          "description": "Raw SQL fragment the aggregate is applied to.",
          "type": "string"
        },
        "filters": {
          "description": "Measure-scoped predicates compiled into a `FILTER (WHERE ...)` clause.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "format": {
          "description": "Display format hint for clients (e.g. `\"$#,##0.00\"`).",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        }
      }
    },
    "MeasureAgg": {
      "description": "The aggregation kind for a [`Measure`].\n\nExternally tagged: unit variants deserialize from a bare string (`agg: count_distinct`), and `Custom` from a map (`agg: { custom: { sql: \"...\" } }`).",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "sum",
            "count",
            "count_distinct",
            "avg",
            "min",
            "max"
          ]
        },
        {
          "type": "object",
          "required": [
            "custom"
          ],
          "properties": {
            "custom": {
              "type": "object",
              "required": [
                "sql"
              ],
              "properties": {
                "sql": {
                  "type": "string"
                }
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "OptimizerDefaults": {
      "description": "Optimizer section under `defaults:`.",
      "type": "object",
      "properties": {
        "coalesce_batches": {
          "default": true,
          "type": "boolean"
        },
        "dynamic_filter_pushdown": {
          "description": "Off in v1; enabled once dynamic-filter pushdown is implemented.",
          "default": false,
          "type": "boolean"
        },
        "join_reorder": {
          "default": true,
          "type": "boolean"
        }
      }
    },
    "PreAggregation": {
      "description": "A declared rollup: a pre-materialized grouping that the matcher can swap in for the base table when it covers the query.",
      "type": "object",
      "required": [
        "dimensions",
        "measures",
        "name"
      ],
      "properties": {
        "dimensions": {
          "description": "Dimension members, possibly grained, e.g. `[\"order_date.day\", \"status\"]`.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "measures": {
          "description": "Measure names defined on the owning model.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "partition_by": {
          "description": "Optional partition member, e.g. `\"order_date.month\"`.",
          "type": [
            "string",
            "null"
          ]
        },
        "refresh": {
          "description": "Refresh cadence; how often the materializer rebuilds the rollup.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Relationship": {
      "description": "A join from one model to another. `join_predicate` is a raw SQL fragment in which `this` aliases the declaring model and the target is referenced by its model name (e.g. `\"this.customer_id = customers.id\"`).",
      "type": "object",
      "required": [
        "kind",
        "name",
        "on",
        "target"
      ],
      "properties": {
        "kind": {
          "$ref": "#/definitions/RelationshipKind"
        },
        "name": {
          "type": "string"
        },
        "on": {
          "description": "SQL join condition; `this` = the declaring model's alias.",
          "type": "string"
        },
        "target": {
          "description": "Name of the model this relationship joins to.",
          "type": "string"
        }
      }
    },
    "RelationshipKind": {
      "description": "Cardinality of a [`Relationship`], which picks the join type: `*-to-one` joins are `INNER`, `*-to-many` are `LEFT`.",
      "type": "string",
      "enum": [
        "many_to_one",
        "one_to_many",
        "one_to_one"
      ]
    },
    "SafetyDefaults": {
      "description": "Safety section under `defaults:`.",
      "type": "object",
      "properties": {
        "max_unfiltered_rows": {
          "description": "Hard cap on returned rows for any source that doesn't declare its own.",
          "default": 1000000,
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "SafetyPolicy": {
      "description": "Restrictions a source can place on its own tables to prevent accidental \"scan the entire warehouse\" queries.",
      "type": "object",
      "properties": {
        "max_pages": {
          "description": "Cap on HTTP pagination calls.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "max_rows": {
          "description": "Hard cap on returned rows.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "require_at_least_one_filter": {
          "description": "If true, refuse to scan with no filter at all.",
          "default": false,
          "type": "boolean"
        },
        "require_filters_on": {
          "description": "Columns that must appear in a filter; empty means no requirement.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_predicates": {
          "description": "Predicates AND-ed into every scan of the owning semantic model. May reference `${param:NAME}` placeholders, bound from `SemanticQuery::params` as escaped SQL literals at compile time (never interpolated as SQL fragments — see `pawrly-semantic`). Used for row-level security and always-on filters.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeout": {
          "description": "Per-query timeout override.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "SecretsBackendDef": {
      "description": "One secret backend in the resolution chain.",
      "oneOf": [
        {
          "description": "Process environment.",
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "env"
              ]
            }
          },
          "additionalProperties": false
        },
        {
          "description": "A file on disk — a YAML map or a dotenv (`.env`) file. The `format` defaults to auto-detection from the file extension. Relative paths resolve against the directory of the declaring config file.",
          "type": "object",
          "required": [
            "kind",
            "path"
          ],
          "properties": {
            "format": {
              "default": "auto",
              "allOf": [
                {
                  "$ref": "#/definitions/SecretsFileFormat"
                }
              ]
            },
            "kind": {
              "type": "string",
              "enum": [
                "file"
              ]
            },
            "path": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "description": "OS keyring under the given service.",
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "keyring"
              ]
            },
            "service": {
              "default": "pawrly",
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Convenience chain: process environment, then the OS keyring (service `pawrly`), then a `.env` file in the config directory if one exists. A missing or insecure `.env` is skipped (with a warning), never fatal.",
          "type": "object",
          "required": [
            "kind"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "auto"
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "SecretsFileFormat": {
      "description": "On-disk format of a [`SecretsBackendDef::File`] backend.",
      "oneOf": [
        {
          "description": "Detect from the file extension (`.env` → dotenv, else YAML).",
          "type": "string",
          "enum": [
            "auto"
          ]
        },
        {
          "description": "A YAML map of `KEY: value`.",
          "type": "string",
          "enum": [
            "yaml"
          ]
        },
        {
          "description": "Dotenv-style `KEY=value` lines.",
          "type": "string",
          "enum": [
            "dotenv"
          ]
        }
      ]
    },
    "Segment": {
      "description": "A named, reusable set of filters defined on a [`SemanticModel`].\n\nA segment is a label that expands into its predicates at compile time, referenced from a [`SemanticQuery`] as `model.segment` (e.g. `\"orders.high_value\"`). `describe_semantic_model` returns the model's segments so a client can discover and compose them, and they are auditable because the predicates live in trusted config — never in the request.",
      "type": "object",
      "required": [
        "filters",
        "name"
      ],
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "filters": {
          "description": "Predicates AND-ed into the query when the segment is selected.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/SemanticFilter"
          }
        },
        "name": {
          "type": "string"
        }
      }
    },
    "SemanticConfig": {
      "description": "The `semantic:` config block — a set of business-named models.",
      "type": "object",
      "properties": {
        "include": {
          "description": "Files (or glob patterns) that contain *only* semantic models, merged into `models` before validation. Each file is either a top-level `models:` list or a bare YAML sequence of model mappings — never sources, secrets, or other config. Resolved relative to the declaring file. The loader consumes this during multi-file assembly, so it is always empty on a fully-loaded `Config`.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "models": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/definitions/SemanticModel"
          }
        }
      },
      "additionalProperties": false
    },
    "SemanticFilter": {
      "description": "A predicate over one member.",
      "type": "object",
      "required": [
        "member",
        "op"
      ],
      "properties": {
        "member": {
          "description": "`\"orders.status\"` or `\"orders.order_date.month\"`.",
          "type": "string"
        },
        "op": {
          "$ref": "#/definitions/FilterOp"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "SemanticModel": {
      "description": "A logical entity anchored on one physical table.",
      "type": "object",
      "required": [
        "dimensions",
        "measures",
        "name",
        "source"
      ],
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "dimensions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Dimension"
          }
        },
        "measures": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Measure"
          }
        },
        "name": {
          "description": "Business name, e.g. `orders`. Used as the member prefix.",
          "type": "string"
        },
        "pre_aggregations": {
          "description": "Declared rollups. The rollup matcher rewrites the `FROM` clause to a materialized pre-agg when one covers the query; materialization itself is handled by the cache layer.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/PreAggregation"
          }
        },
        "primary_key": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "relationships": {
          "description": "Joins to other models, walked by the compiler to answer queries whose members span models.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/Relationship"
          }
        },
        "safety": {
          "description": "Per-model guard rails. `required_predicates` (RLS) are AND-ed into every compiled query for this model.",
          "anyOf": [
            {
              "$ref": "#/definitions/SafetyPolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "segments": {
          "description": "Named, reusable filter sets. A query references one as `model.segment` and the compiler expands it into its predicates before planning.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/Segment"
          }
        },
        "source": {
          "description": "`\"schema.table\"` reference to a table registered in the `pawrly` catalog (schema = source name). Parsed by the compiler, not at deserialization time, so a malformed value surfaces as a query-time error rather than a config-load panic.",
          "type": "string"
        }
      }
    },
    "SourceDef": {
      "description": "One source declaration.",
      "type": "object",
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "cache": {
          "description": "Workspace-level cache override for this source.",
          "default": {
            "mode": "none"
          },
          "allOf": [
            {
              "$ref": "#/definitions/CachePolicy"
            }
          ]
        },
        "config": {
          "description": "Per-kind opaque config. Validated by the source builder when registered."
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "from": {
          "description": "Optional path to a YAML file containing the rest of this source's body. Resolved relative to the declaring file.",
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "$ref": "#/definitions/SourceKind"
        },
        "name": {
          "type": "string"
        },
        "raw_table": {
          "description": "HTTP-shaped sources only: register a raw-HTTP table named after the source.",
          "default": false,
          "type": "boolean"
        },
        "raw_table_safety": {
          "description": "HTTP-shaped sources only: safety policy for the raw table.",
          "anyOf": [
            {
              "$ref": "#/definitions/SafetyPolicy"
            },
            {
