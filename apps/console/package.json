{
  "name": "pawrly-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate": "buf generate ../../crates/pawrly-proto/proto",
    "catalog": "node scripts/build-catalog.mjs",
    "dev": "pnpm run catalog && vite",
    "build": "pnpm run catalog && pnpm run generate && tsc -b && vite build",
    "typecheck": "pnpm run catalog && tsc -b --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.9.0",
    "@connectrpc/connect": "^2.1.0",
    "@connectrpc/connect-web": "^2.1.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.15",
    "apache-arrow": "^18.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.59.0",
    "@bufbuild/protoc-gen-es": "^2.9.0",
    "@tailwindcss/vite": "^4.1.16",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@bufbuild/buf",
      "esbuild"
    ]
  }
}
